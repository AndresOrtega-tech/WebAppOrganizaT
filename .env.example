# Base de backend usada por el proxy interno /api/backend (server-side).
# En Minikube apunta al servicio interno del cluster.
BACKEND_API_BASE_URL=http://organizat-backend.default.svc.cluster.local:8000/api

# URL pública local opcional del frontend para operaciones server-side.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Compatibilidad temporal con configuración previa.
NEXT_PUBLIC_USE_DEV_API=true
NEXT_PUBLIC_DEV_BACKEND_URL=http://organizat-backend.default.svc.cluster.local:8000/api
NEXT_PUBLIC_BACKEND_URL=http://organizat-backend.default.svc.cluster.local:8000/api

# Gemini key for Next route handlers in /api/ai/*
GEMINI_API_KEY=replace-with-your-key